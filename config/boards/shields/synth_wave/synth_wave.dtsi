#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/rgb.h>

&usbd {
    status = "okay";
    cdc_acm_uart: cdc_acm_uart {
        compatible = "zephyr,cdc-acm-uart";
    };
};

/ {
    keys {
		compatible = "gpio-keys";
		wakeup_key: wakeup_key {
			gpios = <&pro_micro 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
		};
        wakeup_pin: wakeup_pin {
			gpios = <&pro_micro 4 GPIO_ACTIVE_HIGH>;
		};
	};
    
    behaviors {
        sensors: sensors {
            compatible = "zmk,keymap-sensors";
            sensors = <&left_encoder &right_encoder>;
            triggers-per-rotation = <20>;
        };
        rgb_encoder: rgb_encoder {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&rgb_ug RGB_EFF>, <&rgb_ug RGB_EFR>;
        };
        bt_encoder: bt_encoder {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&bt BT_NXT>, <&bt BT_PRV>;
        };
		hw_soft_off: hw_soft_off {
			compatible = "zmk,behavior-soft-off";
			#binding-cells = <0>;
		};
    };

    soft_off_direct_scan: soft_off_direct_scan {
		compatible = "zmk,kscan-gpio-direct";
		input-keys = <&wakeup_key>;
	};

	wakeup_source: wakeup_source {
		compatible = "zmk,gpio-key-wakeup-trigger";
		
		trigger = <&wakeup_key>;
        extra-gpios: <&wakeup_pin>;
		wakeup-source;
	};

        soft_off_wakers {
		compatible = "zmk,soft-off-wakeup-sources";
		wakeup-sources = <&wakeup_source>;
	};
    side_band_behavior_triggers {
		compatible = "zmk,kscan-sideband-behaviors";
		wakeup-source;
		kscan = <&soft_off_direct_scan>;
		soft_off {
			column = <3>;
			row = <0>;
			bindings = <&hw_soft_off>;
		};
	};
    
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;

        /delete-property/ zephyr,console;
        /delete-property/ zephyr,shell-uart;

        zephyr,console = &cdc_acm_uart;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <7>;

        map = <
            RC(3,0) RC(0,3) RC(3,1) RC(1,3) RC(3,2) RC(2,3)      RC(3,7) RC(0,10) RC(3,8) RC(1,10) RC(3,9) RC(2,10)
            RC(4,0) RC(0,4) RC(4,1) RC(1,4) RC(4,2) RC(2,4)      RC(4,7) RC(0,11) RC(4,8) RC(1,11) RC(4,9) RC(2,11)
            RC(5,0) RC(0,5) RC(5,1) RC(1,5) RC(5,2) RC(2,5)      RC(5,7) RC(0,12) RC(5,8) RC(1,12) RC(5,9) RC(2,12)
                            RC(6,1) RC(1,6) RC(6,2) RC(2,6)      RC(6,8) RC(1,13) RC(6,9) RC(2,13)
        >;
    };

    kscan0: kscan_0 {
        compatible = "zmk,kscan-gpio-charlieplex";
        wakeup-source;
    };

    left_encoder: encoder_left {
        compatible = "alps,ec11";
        steps = <80>;
        status = "disabled";
        label = "encoder_left";
    };
    right_encoder: encoder_right {
        compatible = "alps,ec11";
        steps = <80>;
        status = "disabled";
        label = "encoder_right";
    };
};